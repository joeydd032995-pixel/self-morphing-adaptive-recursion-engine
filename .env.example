# Copy this file to .env and fill in what you need.
# Nothing below is required for the CLI or direct Python usage (see GETTING_STARTED.md
# Options 1 & 2) — those work out of the box with a deterministic mock LLM.

# --- Required for the FastAPI server only (Option 3 in GETTING_STARTED.md) ---
# The server raises RuntimeError and refuses to start if this is unset.
ENGINE_API_KEY=

# --- Optional: LLM providers (PoG planning, self-teaching, advanced RAG query rewriting/agentic hops) ---
# If both are unset, the engine uses a deterministic mock LLM — fine for demos/tests,
# not for real reasoning quality. If both are set, GROQ_API_KEY takes precedence.
OPENAI_API_KEY=
GROQ_API_KEY=

# --- Optional: Neo4j (external knowledge-graph sync; the SQLite KG always works without this) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- Optional: storage paths ---
ENGINE_DB_PATH=engine_logs.db
ENGINE_FAISS_INDEX_PATH=faiss_index.bin
ENGINE_GNN_MODEL_PATH=gnn_model.pt

# --- Optional: model selection ---
ENGINE_EMBEDDING_MODEL=all-MiniLM-L6-v2
ENGINE_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Optional: scaling / ops tuning ---
# Vector count above which the FAISS index switches to HNSW.
ENGINE_FAISS_HNSW_THRESHOLD=10000
# Only active if the optional `slowapi` dependency is installed.
RATE_LIMIT=120/minute
LOG_LEVEL=INFO
